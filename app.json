{
  "expo": {
    "name": "HomeLog",
    "slug": "homelog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5f4f0"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.homelog.app",
      "infoPlist": {
        "NSCameraUsageDescription": "HomeLog bruker kameraet for å skanne dokumenter og kvitteringer.",
        "NSPhotoLibraryUsageDescription": "HomeLog trenger tilgang til bilder for å laste opp dokumenter."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f5f4f0"
      },
      "package": "com.homelog.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        { "cameraPermission": "HomeLog bruker kameraet for å skanne dokumenter." }
      ],
      [
        "expo-image-picker",
        { "photosPermission": "HomeLog trenger tilgang til bilder." }
      ]
    ],
    "scheme": "homelog",
    "experiments": {
      "typedRoutes": true
    }
  }
}
